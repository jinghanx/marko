{
  "name": "marko",
  "version": "0.1.0",
  "private": true,
  "description": "A Typora-like markdown editor for macOS",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "package:mac": "npm run build && electron-builder --mac --arm64 --x64",
    "preview": "vite preview",
    "rename:dev-electron": "bash scripts/rename-dev-electron.sh"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.20.0",
    "@replit/codemirror-vim": "^6.3.0",
    "fzf": "^0.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.marko.app",
    "productName": "Marko",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ]
    }
  }
}
